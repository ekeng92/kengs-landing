  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240806.0",
    "@types/node": "^25.6.0",
    "postgres": "^3.4.9",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5",
    "wrangler": "^3.65.0"
  }
}
