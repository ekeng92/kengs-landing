{
  "name": "kengs-landing-api",
  "version": "0.0.1",
  "private": true,
  "description": "STR Finance API — Keng's Landing backend (Hono + Cloudflare Workers + Supabase)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
